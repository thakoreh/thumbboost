{
  "name": "thumbboost",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preflight": "NODE_OPTIONS='--experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON' node scripts/preflight.mjs",
    "test": "NODE_OPTIONS='--experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON' node --test 'tests/**/*.test.ts'",
    "start": "rm -rf .next/standalone/.next/static .next/standalone/public && mkdir -p .next/standalone/.next && cp -R .next/static .next/standalone/.next/static && cp -R public .next/standalone/public && node .next/standalone/server.js",
    "lint": "eslint"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.3",
    "@phosphor-icons/react": "^2.1.10",
    "convex": "^1.40.0",
    "next": "16.2.7",
    "openai": "^6.42.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
